# Example environment for live Gazebo stack (Windows cmd → set, or WSL export).
# World name must match worlds/empty_world.sdf (<world name="empty_world">).

GZ_SIM_CONTAINER_NAME=gz-sim-sever
ROS_GZ_BRIDGE_CONTAINER=ros-gz-bridge
GZ_SIM_WORLD_NAME=empty_world
GAZEBO_WORLD_NAME=empty_world
GZ_SIM_RESOURCE_PATH=/models

# Live handoff / pytest
GAZEBO_MCP_DOCKER=1
GAZEBO_SPAWN_VIA_GZ_CLI=1
RUN_GAZEBO_LIVE=1
